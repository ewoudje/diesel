$C = "../Common.ui";
$Sounds = "../Sounds.ui";

@InputLabel = Label {
  Anchor: (Left: 6, Right: 16, Width: 100);
  Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center, Wrap: true);
};

@OperatorDropdown = DropdownBox {
    Anchor: (Left: 15, Width: 70, Height: $C.@DropdownBoxHeight);
    Style: $C.@DefaultDropdownBoxStyle;
    Value: "OR";

    DropdownEntry {
        Value: "OR";
        Text: "OR";
    }

    DropdownEntry {
        Value: "AND";
        Text: "AND";
    }
};

@ComparisonDropdown = DropdownBox {
    Anchor: (Width: 60, Height: $C.@DropdownBoxHeight);
    Style: $C.@DefaultDropdownBoxStyle;
    Value: "EQUAL";

    DropdownEntry {
        Value: "EQUAL";
        Text: "==";
    }

    DropdownEntry {
        Value: "NOT_EQUAL";
        Text: "!=";
    }

    DropdownEntry {
        Value: "GREATER";
        Text: ">";
    }

    DropdownEntry {
        Value: "LESSER";
        Text: "<";
    }

    DropdownEntry {
        Value: "GREATER_OR_EQUAL";
        Text: ">=";
    }

    DropdownEntry {
        Value: "LESS_OR_EQUAL";
        Text: "<=";
    }
};

@Entry = Group {
  LayoutMode: Left;
  Anchor: (Bottom: 16);

  $C.@TextField #LogicId {
    @Anchor = (Width: 150, Left: 15, Right: 15);
    PlaceholderText: "anyString";
  }

  @ComparisonDropdown #LogicComparison {}

  $C.@TextField #LogicValue {
    @Anchor = (Width: 150, Left: 15);
    PlaceholderText: "anyString";
  }
};

$C.@Container {
  Anchor: (Left: 50, Top: 170, Width: 480, Height: 550);

  #Title {
    Group {
      LayoutMode: Left;
      $C.@Title {
        @Text = %server.customUI.stateWriter.title;
      }
    }

    $C.@HeaderSearch {}
  }

  #Content {
    Group {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group {
        LayoutMode: Left;
        Anchor: (Bottom: 16);

        @InputLabel {
          Text: %server.customUI.stateReader.logicId;
        }

        $C.@TextField #LogicId {
          @Anchor = (Width: 200);
          PlaceholderText: "anyString";
        }

        @OperatorDropdown #LogicOperator {
        }
      }


      @Entry #Entry1 {

      }

    
      @Entry #Entry2 {
        
      }
      
      @Entry #Entry3 {
        
      }
      
      @Entry #Entry4 {
       
      }
      
      @Entry #Entry5 {
        
      }
      
      @Entry #Entry6 {
        
      }

      $C.@TextButton #ApplyButton {
        @Sounds = $Sounds.@SaveSettings;
        @Anchor = (Right: 4, Top: 5);
        Padding: (Full: 16);
        Text: %server.customUI.stateReader.apply;
        FlexWeight: 1;
      }
    }
  }
}

$C.@BackButton {}
